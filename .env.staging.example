# Placeholder template only. Do not commit real .env files or real values.
# Put real staging values in the platform secret manager or an ignored local .env file.
# Rotate any value immediately if it is pasted, printed, committed, or screenshotted.

NODE_ENV="staging"
APP_ENV="staging"
PORT="4000"

# Database staging/test only. Secret manager only, never production.
DATABASE_URL="<staging-database-url>"

# Admin/session/auth. Secret manager only. Use staging-only generated values.
JWT_SECRET="<set-in-platform-secret-manager>"
LOCAL_ADMIN_PASSWORD="<set-in-platform-secret-manager>"
JWT_EXPIRES_IN="7d"

# CORS/base URL. Keep staging/test only.
CORS_ORIGIN="https://<staging-frontend-or-admin-origin>"
PUBLIC_API_BASE_URL="https://<staging-domain>"

# Provider/game mock/sandbox/disabled.
GAME_PROVIDER_MODE="mock"
GAME_PROVIDER_API_BASE_URL="<set-in-platform-secret-manager-or-empty>"
GAME_PROVIDER_AGENT_CODE=""
GAME_PROVIDER_API_KEY="<set-in-platform-secret-manager-or-empty>"
GAME_PROVIDER_SECRET="<set-in-platform-secret-manager-or-empty>"

# Payment mock/sandbox/disabled.
PAYMENT_PROVIDER_MODE="mock"
PAYMENT_API_BASE_URL="<set-in-platform-secret-manager-or-empty>"
PAYMENT_MERCHANT_ID=""
PAYMENT_API_KEY="<set-in-platform-secret-manager-or-empty>"
PAYMENT_SECRET="<set-in-platform-secret-manager-or-empty>"

# Bank/statement mock/sandbox/disabled.
BANK_STATEMENT_MODE="mock"
BANK_API_BASE_URL="<set-in-platform-secret-manager-or-empty>"
BANK_API_KEY="<set-in-platform-secret-manager-or-empty>"

# SMS mock/sandbox/disabled.
SMS_PROVIDER_MODE="mock"
SMS_API_BASE_URL="<set-in-platform-secret-manager-or-empty>"
SMS_API_KEY="<set-in-platform-secret-manager-or-empty>"

# Slip OCR mock/sandbox/disabled.
SLIP_OCR_MODE="mock"
SLIP_OCR_API_BASE_URL="<set-in-platform-secret-manager-or-empty>"
SLIP_OCR_API_KEY="<set-in-platform-secret-manager-or-empty>"

# Mock mode leaves provider credentials empty.
# Sandbox mode may use provider API URLs and credentials, but those values must be set
# in the platform secret manager only and must never be committed.
# Live mode is forbidden for staging preparation.
