# Placeholder template only. Do not commit real .env files or real values.
# Put real staging values in the platform secret manager, not in this file.
# For Render, put real values in the Render dashboard Environment tab or an
# approved Render Environment Group only. Never paste real values into repo files.
# Local ignored .env files may be used only for safe local staging/test verification.
# Rotate any value immediately if it is pasted, printed, committed, or screenshotted.
#
# Secret-scan note:
# - The database key is documented as a mapping line below, not an assignment.
# - When configuring the platform, set the exact key name `DATABASE_URL` there.
# - Do not paste the actual database URL into this repository.

# App runtime. Staging mock/sandbox preflight must not run with NODE_ENV production.
NODE_ENV="staging"
APP_ENV="staging"
STAGING_MODE="mock"
PORT="4000"

# Database staging/test only. Render dashboard/platform secret manager only, never production.
# DATABASE_URL -> <SET_IN_PLATFORM_SECRET>

# Admin/session/auth. Render dashboard/platform secret manager only. Use staging-only generated values.
JWT_SECRET="<SET_IN_PLATFORM_SECRET>"
LOCAL_ADMIN_PASSWORD="<SET_IN_PLATFORM_SECRET>"
JWT_EXPIRES_IN="7d"

# Staging UAT demo admin. Placeholder only; set real values in Render Environment.
STAGING_DEMO_ADMIN_EMAIL="<SET_IN_PLATFORM_SECRET>"
STAGING_DEMO_ADMIN_PASSWORD="<SET_IN_PLATFORM_SECRET>"
STAGING_DEMO_SEED_ENABLED="true"

# Staging UAT demo member. Placeholder only; set real values in Render Environment.
# Member auth endpoint is POST /api/auth/login with body { "phone": <username-or-phone>, "password": <password> }.
# Seed requires both username and phone so reruns can refresh the same staging fixture safely.
STAGING_DEMO_MEMBER_USERNAME=
STAGING_DEMO_MEMBER_PHONE=
STAGING_DEMO_MEMBER_PASSWORD=

# Staging role-permission UAT limited admin fixtures. Password values must be set
# only in Render/secret manager. Login identifiers must contain staging/demo/test
# markers and must not be real customer or production-like accounts.
STAGING_NO_PERMISSION_ADMIN_EMAIL=
STAGING_NO_PERMISSION_ADMIN_USERNAME=
STAGING_NO_PERMISSION_ADMIN_PASSWORD=
STAGING_SAFE_ROLE_NAME="staging_safe_role"
STAGING_SAFE_ROLE_ADMIN_EMAIL=
STAGING_SAFE_ROLE_ADMIN_USERNAME=
STAGING_SAFE_ROLE_ADMIN_PASSWORD=

# CORS/base URL. Keep staging/test only.
CORS_ORIGIN="https://<STAGING_FRONTEND_OR_ADMIN_ORIGIN>"
PUBLIC_API_BASE_URL="https://<STAGING_DOMAIN>"

# Provider/game mock/sandbox/disabled. Never use live mode in Render staging.
# mock: leave API URL and credentials empty or placeholder-only.
# sandbox: set sandbox URL/credentials only in the platform secret manager.
GAME_PROVIDER_MODE="mock"
GAME_PROVIDER_API_BASE_URL="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"
GAME_PROVIDER_AGENT_CODE=""
GAME_PROVIDER_API_KEY="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"
GAME_PROVIDER_SECRET="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"

# Payment mock/sandbox/disabled. No real payment rails or real-money payout.
PAYMENT_PROVIDER_MODE="mock"
PAYMENT_API_BASE_URL="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"
PAYMENT_MERCHANT_ID=""
PAYMENT_API_KEY="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"
PAYMENT_SECRET="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"

# Bank/statement mock/sandbox/disabled. No live bank rails.
BANK_STATEMENT_MODE="mock"
BANK_API_BASE_URL="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"
BANK_API_KEY="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"

# SMS mock/sandbox/disabled. No live SMS sending.
SMS_PROVIDER_MODE="mock"
SMS_API_BASE_URL="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"
SMS_API_KEY="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"

# Slip OCR mock/sandbox/disabled. No live OCR provider connection.
SLIP_OCR_MODE="mock"
SLIP_OCR_API_BASE_URL="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"
SLIP_OCR_API_KEY="<SET_IN_PLATFORM_SECRET_OR_EMPTY_FOR_MOCK>"

# Live mode is forbidden for staging mock/sandbox preflight.
# Do not add production DB, production credentials, real bank, payment, SMS, or Slip OCR values.
