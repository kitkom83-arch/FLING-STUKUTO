# Placeholder template only. Do not commit real .env files or real values.
# Put real staging values in the platform secret manager or an ignored local .env file.
# Rotate any value immediately if it is pasted, printed, committed, or screenshotted.

NODE_ENV="staging"
APP_ENV="staging"
PORT="4000"

# Secret manager only. Must target dedicated staging/test PostgreSQL, never production.
DATABASE_URL="<SET_IN_PLATFORM_SECRET_MANAGER>"

# Secret manager only. Use staging-only generated values, never production values.
JWT_SECRET="<SET_IN_PLATFORM_SECRET_MANAGER>"
LOCAL_ADMIN_PASSWORD="<SET_IN_PLATFORM_SECRET_MANAGER>"
JWT_EXPIRES_IN="7d"

# Non-secret staging host values. Keep them staging/test only.
CORS_ORIGIN="https://<STAGING_FRONTEND_OR_ADMIN_ORIGIN>"
PUBLIC_API_BASE_URL="https://<STAGING_API_HOST>"

GAME_PROVIDER_MODE="mock"
GAME_PROVIDER_API_BASE_URL=""
GAME_PROVIDER_AGENT_CODE=""
GAME_PROVIDER_API_KEY=""
GAME_PROVIDER_SECRET=""

PAYMENT_PROVIDER_MODE="mock"
PAYMENT_API_BASE_URL=""
PAYMENT_MERCHANT_ID=""
PAYMENT_API_KEY=""
PAYMENT_SECRET=""

BANK_STATEMENT_MODE="mock"
BANK_API_BASE_URL=""
BANK_API_KEY=""

SMS_PROVIDER_MODE="mock"
SMS_API_BASE_URL=""
SMS_API_KEY=""

SLIP_OCR_MODE="mock"
SLIP_OCR_API_BASE_URL=""
SLIP_OCR_API_KEY=""

# Mock mode leaves provider credentials empty.
# Sandbox mode may use provider API URLs and credentials, but those values must be set
# in the platform secret manager only and must never be committed.
# Live mode is forbidden for staging preparation.
