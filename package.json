{
  "name": "pg77-real-core-backend",
  "version": "0.1.0",
  "description": "PG77 Real Core Backend API with mock game, payment, and bank integrations.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "prisma db seed",
    "check": "node --check src/server.js && node --check src/app.js && node --check prisma/seed.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.7.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
